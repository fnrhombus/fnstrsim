{
  "name": "fnstrsim",
  "version": "0.1.0",
  "description": "Multi-algorithm string similarity for TypeScript. Drop-in replacement for string-similarity with Dice, Jaro-Winkler, Levenshtein, and cosine.",
  "keywords": [
    "string-similarity",
    "string-compare",
    "levenshtein",
    "jaro-winkler",
    "dice-coefficient",
    "cosine-similarity",
    "fuzzy-match",
    "edit-distance"
  ],
  "license": "MIT",
  "author": "fnrhombus",
  "repository": {
    "type": "git",
    "url": "https://github.com/fnrhombus/fnstrsim"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
